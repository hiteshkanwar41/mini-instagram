<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/show.css">
    <title>Document</title>
</head>
<body>
    <h2>@<%=post.username%></h2>
    <h4><%=post.content%></h4>
    
    <% for (image of post.images){  %>
        <div class="cont">
            <img src="<%=image.url%>" alt="image">
        </div>
        <a href="http://localhost:8080/posts/<%=post.id%>/edit" class="action-btn">edit</a>
    <% } %>
</body>
</html>